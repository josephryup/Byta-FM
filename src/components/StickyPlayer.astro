<div class="sticky-player-bar" data-sticky-player>
  <div class="sticky-player-inner">
    <div class="sticky-player-main">
      <div class="sticky-status">
        <span class="pulse-dot"></span>
        <span>On air</span>
      </div>
      <div class="sticky-player-track">
        <strong data-now-playing>Byta Breakfast</strong>
        <span data-now-playing-sub>06:00 CAT | Headlines, market updates, weather, and shout-outs</span>
      </div>
    </div>

    <div class="sticky-actions">
      <button class="button button-primary" type="button" data-load-stream>Listen live</button>
      <a class="sticky-link" href="#" target="_blank" rel="noreferrer" data-stream-link>Open stream</a>
    </div>

    <button class="sticky-close" type="button" aria-label="Hide floating player" data-sticky-close>
      <span aria-hidden="true">×</span>
    </button>
  </div>
</div>
