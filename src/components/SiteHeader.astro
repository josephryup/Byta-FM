---
import { navItems, stationInfo } from "../data/site";

interface Props {
  activePath: string;
}

const { activePath } = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Byta FM home">
      <div class="brand-mark">
        <img src="/assets/logo.webp" alt="Byta FM logo" width="256" height="256" decoding="async" fetchpriority="high" />
      </div>
      <div class="brand-copy">
        <strong>Byta FM 90.3</strong>
        <span>Choma and Mazabuka</span>
      </div>
    </a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-label="Open navigation" data-nav-toggle>
      <span>Menu</span>
    </button>
    <nav class="site-nav" aria-label="Primary" data-nav>
      {
        navItems.map((item) => (
          <a class:list={{ active: activePath === item.href }} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="header-actions">
      <a
        class="button button-ghost button-icon"
        href={stationInfo.whatsappUrl}
        target="_blank"
        rel="noreferrer"
        aria-label={`Open WhatsApp chat with ${stationInfo.name}`}
      >
        <svg class="button-icon-mark" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M19.1 4.9A9.84 9.84 0 0 0 12.05 2C6.58 2 2.13 6.45 2.13 11.92c0 1.75.46 3.46 1.33 4.97L2 22l5.27-1.38a9.84 9.84 0 0 0 4.75 1.21h.01c5.47 0 9.92-4.45 9.92-9.92A9.83 9.83 0 0 0 19.1 4.9Zm-7.08 15.26h-.01a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.13.82.84-3.05-.2-.31a8.2 8.2 0 0 1-1.27-4.38c0-4.52 3.68-8.2 8.21-8.2a8.2 8.2 0 0 1 5.8 2.4 8.15 8.15 0 0 1 2.4 5.8c0 4.52-3.68 8.2-8.16 8.24Zm4.5-6.15c-.25-.13-1.47-.72-1.7-.8-.23-.08-.4-.13-.57.13-.17.25-.65.8-.8.96-.15.17-.3.19-.55.07-.25-.13-1.07-.39-2.04-1.25-.75-.67-1.26-1.5-1.41-1.75-.15-.25-.02-.38.11-.51.12-.12.25-.3.38-.44.13-.15.17-.25.25-.42.08-.17.04-.32-.02-.44-.07-.13-.57-1.37-.78-1.87-.2-.49-.41-.42-.57-.43h-.49c-.17 0-.44.06-.67.32-.23.25-.88.86-.88 2.1 0 1.24.9 2.44 1.03 2.61.13.17 1.76 2.68 4.27 3.76.6.26 1.07.42 1.44.53.6.19 1.15.16 1.59.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.15-1.18-.06-.1-.23-.16-.48-.29Z"/>
        </svg>
        <span>WhatsApp</span>
      </a>
      <button class="button button-primary" type="button" data-load-stream>Listen live</button>
    </div>
  </div>
</header>
